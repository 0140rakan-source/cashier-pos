# Cashier POS — Environment Configuration
# Copy this file to .env and customize for each installation

# Database — SQLite (local file, no server needed)
DATABASE_URL="file:../../data/cashier.db"

# Authentication
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_STRING
JWT_EXPIRES_IN=24h

# Server
PORT=3001
NODE_ENV=production

# Activation — DO NOT share this secret with customers
# ACTIVATION_SECRET="REPLACE_WITH_RANDOM_64_HEX"
